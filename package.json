{
  "name": "slashwork-github-integration",
  "private": true,
  "version": "0.0.0",
  "type": "module",
  "scripts": {
    "build": "esbuild --platform=node --target=node22 --bundle --packages=external --format=esm --sourcemap --outfile=dist/server.js src/server.ts",
    "server": "node --env-file .env --enable-source-maps dist/server.js",
    "check": "tsc && eslint ."
  },
  "devDependencies": {
    "@eslint/js": "^9.39.2",
    "@types/express": "^5.0.6",
    "@types/node": "^25.0.3",
    "esbuild": "^0.27.2",
    "eslint": "^9.39.2",
    "eslint-config-prettier": "^10.1.8",
    "eslint-plugin-import": "^2.32.0",
    "eslint-plugin-no-relative-import-paths": "^1.6.1",
    "eslint-plugin-prettier": "^5.5.4",
    "globals": "^17.0.0",
    "typescript": "~5.9.3",
    "typescript-eslint": "^8.52.0"
  },
  "dependencies": {
    "express": "^5.2.1"
  }
}
